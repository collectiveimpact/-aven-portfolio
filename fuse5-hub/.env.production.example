# ── Fuse5 Hub — production environment template ──────────────────────────────
# Copy to your host's env settings (Vercel project env, container env, etc.).
# Each key flips a feature from safe-stub to live. The app boots without the
# optional ones (they degrade to stubs), so you can launch incrementally.

# ── Required: cloud database (Supabase project, ca-central-1) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
# Server-only — used by the bootstrap script + any privileged server task. NEVER
# expose this to the browser (no NEXT_PUBLIC_ prefix). Do not commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Turn off demo affordances in production ─────────────────────────────────
# Hides the prefilled login creds + "Demo:" hint. Auto-off when NODE_ENV=production,
# but set explicitly to be safe. Set to "true" only for a public demo instance.
NEXT_PUBLIC_DEMO=false

# ── Optional: AI copy (Compose / Notice Studio / AI Agents) ─────────────────
# Without this, AI generation returns deterministic stub text.
ANTHROPIC_API_KEY=

# ── Optional: email send (broadcasts, notices) ─────────────────────────────
# Resend-compatible. Without it, email "sends" are logged stubs.
RESEND_API_KEY=

# ── Optional: SMS / voice (broadcasts, emergencies) ────────────────────────
# All three required to activate SMS. Without them, SMS "sends" are stubs.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Optional: billing (Admin → License & Billing) ──────────────────────────
# The billing panel is display-only until Stripe is wired. Placeholder for when
# you connect it.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
